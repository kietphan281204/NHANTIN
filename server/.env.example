PORT=8080

# Comma-separated list of allowed origins (your static site domains)
# Example: https://your-site.netlify.app,https://yourdomain.com
ALLOWED_ORIGINS=

# Simple shared secret to prevent abuse (set a strong random string)
UPLOAD_SECRET=

# Gmail SMTP (App Password required; enable 2FA in Google account)
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recipient
TO_EMAIL=kietphan28122004@gmail.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=yourtelegrambottoken
TELEGRAM_CHAT_ID=yourtelegramchatid

# Limits
MAX_FILES=5
MAX_TOTAL_MB=20

